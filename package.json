{
  "name": "memosprout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Verified, portable knowledge for improving future AI-agent runs.",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "next build",
    "check:generated": "pnpm --dir demo/generated-files/template check:generated",
    "demo": "vitest run tests/scenario demo/generated-files/template/tests --reporter=verbose",
    "dev": "next dev",
    "lint": "eslint .",
    "phase2:live": "tsx --env-file=.env scripts/generate-live-candidate.ts",
    "phase2:verify": "tsx scripts/verify-phase2.ts",
    "phase3:live": "tsx scripts/generate-protection.ts",
    "phase3:verify": "tsx scripts/verify-phase3.ts",
    "phase4:baseline": "tsx scripts/capture-baseline.ts",
    "phase4:live": "tsx scripts/run-eval.ts",
    "phase4:verify": "tsx scripts/verify-phase4.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.4",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
