# Required only for live GPT-5.6 Candidate Sprout generation.
OPENAI_API_KEY=

# REST API server (pnpm api)
MEMOSPROUT_API_KEY=            # required to expose the API beyond localhost
MEMOSPROUT_HOST=127.0.0.1      # bind host; non-loopback requires MEMOSPROUT_API_KEY
MEMOSPROUT_CORS_ORIGIN=*       # allowed CORS origin
MEMOSPROUT_PORT=3456
MEMOSPROUT_RATE_LIMIT=120      # max requests/min per API key (0 = disable)
MEMOSPROUT_DIR=corrections

# LLM for /process and pnpm test:live (correction detection + extraction).
# Pick a supported provider (see docs/PROVIDERS.md): openai, anthropic,
# deepseek, qwen, kimi, xiaomi, minimax, groq, togetherai, openrouter, ollama.
# Custom endpoints: provider "openai-compatible" or "anthropic-compatible"
# with BASE_URL + MODEL set explicitly.
MEMOSPROUT_LLM_PROVIDER=
MEMOSPROUT_LLM_BASE_URL=
MEMOSPROUT_LLM_API_KEY=
MEMOSPROUT_LLM_MODEL=
