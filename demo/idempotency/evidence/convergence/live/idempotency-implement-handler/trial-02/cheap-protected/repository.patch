 const statusByType: Record<PaymentEvent["type"], OrderStatus> = {
   payment_pending: "pending",
@@ -7,13 +7,30 @@ const statusByType: Record<PaymentEvent["type"], OrderStatus> = {
   payment_failed: "failed",
 };
 
+function shouldApplyStatus(current: Order | undefined, nextStatus: OrderStatus): boolean {
+  if (!current) return true;
+  if (current.status === "paid" || current.status === "failed") return false;
+  return current.status !== nextStatus;
+}
+
 export function handlePaymentEvent(store: PaymentStore, event: PaymentEvent): void {
-  store.upsertOrder({
-    orderId: event.orderId,
-    status: statusByType[event.type],
-    amountCents: event.amountCents,
