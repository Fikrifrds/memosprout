-  if (event.type === "payment_succeeded") {
+  if (store.hasProcessedEvent(event.eventId)) return;
+
+  const nextStatus = statusByType[event.type];
+  const current = store.getOrder(event.orderId);
+  const applyStatus = shouldApplyStatus(current, nextStatus);
+
+  if (applyStatus) {
+    store.upsertOrder({
+      orderId: event.orderId,
+      status: nextStatus,
+      amountCents: event.amountCents,
+    });
+  }
+
+  if (event.type === "payment_succeeded" && current?.status !== "paid") {
     store.recordCharge(event.orderId, event.amountCents);
   }
+
+  store.markEventProcessed(event.eventId);
 }
