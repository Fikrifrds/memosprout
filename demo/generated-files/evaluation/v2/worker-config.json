  "outputSchemaPath": "demo/generated-files/evaluation/v2/schemas/worker-output.schema.json",
  "isolatedRuntimeContractPath": "demo/generated-files/evaluation/v2/isolated-runtime.json",
  "sanitizedCommand": "codex exec --ignore-user-config --strict-config --json --sandbox workspace-write --ephemeral --model gpt-5.4-mini -c model_reasoning_effort=low -c approval_policy=never -c web_search=disabled --disable multi_agent --output-schema <v2-worker-output-schema> -C <temporary-repository> -"
}
